# ============================================================
# .env.example — ChronosTek CRM Backend
# ============================================================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA versionar o .env real (adicione ao .gitignore).
# ============================================================

# ── Ambiente ─────────────────────────────────────────────────
# Valores: development | production
NODE_ENV=development

# ── Servidor ─────────────────────────────────────────────────
PORT=5000

# ── Banco de dados ───────────────────────────────────────────
# Formato: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/buffet_crm

# ── Autenticação JWT ─────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimo 32 chars. Em producao use 64+ bytes hexadecimais.
JWT_SECRET=replace_with_64_bytes_random_secret_never_use_this_in_production

# ── CORS ─────────────────────────────────────────────────────
# URL do frontend (usada nos avisos de startup)
FRONTEND_URL=http://localhost:3000

# Lista de origens permitidas separadas por virgula.
# Em producao: colocar APENAS o dominio real, sem wildcards.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Setup Route ──────────────────────────────────────────────
# Habilitar apenas para o primeiro setup. Desabilitar depois.
# Em producao tambem requer header X-Setup-Secret.
ALLOW_SETUP=false
SETUP_SECRET=
